[Unit]
Description=ChoirBox Dev
After=network.target

[Service]
Type=simple
User=joerg
WorkingDirectory=/home/joerg/choirbox-dev
Environment=PORT=8002
Environment=HOST=0.0.0.0
Environment=UVICORN_RELOAD=false
ExecStart=/home/joerg/choirbox-dev/venv/bin/python run.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
