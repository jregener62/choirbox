# ChoirBox Configuration

# Admin account (created on first start)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Registration code (shared by admin to choir members)
REGISTRATION_CODE=MeinChor2026

# Dropbox OAuth2 (own ChoirBox app in Dropbox Developer Console)
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REDIRECT_URI=http://localhost:8001/api/dropbox/callback

# GitHub Issue Reporting (optional)
GITHUB_TOKEN=
GITHUB_REPO=

# Security
SECRET_KEY=dev-secret-change-in-production

# Server
PORT=8001
HOST=127.0.0.1
